# ===================================================
# SCOPEIQ ENVIRONMENT CONFIGURATION
# ===================================================
# LOCAL DEV:     Copy .env.local.example → .env.local
# PRODUCTION:    Set in Vercel Dashboard → Environment Variables
# See docs/ENVIRONMENT.md for complete setup guide
# ===================================================

# -- CORE SERVICES --
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000  # Frontend needs this!
AI_SERVICE_URL=http://localhost:8000

# -- CORS (Comma-separated list of allowed frontend origins) --
# Local: http://localhost:3000
# Production: https://scopeiq-web.vercel.app,https://scopeiq.app
ALLOWED_ORIGINS=http://localhost:3000

# -- DATABASE (PostgreSQL 15) --
DATABASE_URL=postgres://scopeiq:scopeiq_dev@localhost:5432/scopeiq

# -- REDIS (Cache & Queues) --
REDIS_URL=redis://localhost:6379

# -- STORAGE (MinIO/S3) --
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=scopeiq
STORAGE_SECRET_KEY=scopeiq_dev
STORAGE_BUCKET=scopeiq-assets
STORAGE_USE_SSL=false

# -- AI CONFIG --
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
AI_CALLBACK_SECRET=generate_a_secure_random_secret_here

# -- SECURITY (required in production, min 32 chars) --
EMAIL_APPROVAL_SECRET=generate_a_secure_random_secret_here_min_32_chars
# Signs pagination cursors with HMAC-SHA256 to prevent forgery and workspace leakage
CURSOR_SIGNING_SECRET=generate_a_secure_random_secret_here_min_32_chars

# -- AUTH & EXTERNAL --
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
SENTRY_DSN=...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
