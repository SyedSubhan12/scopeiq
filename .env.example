# -- CORE SERVICES --
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# -- CORS (Comma-separated list of allowed frontend origins) --
# For production, set this to your Vercel deployment URL
# ALLOWED_ORIGINS=https://scopeiq.vercel.app,https://scopeiq.app

# -- DATABASE (PostgreSQL 15) --
DATABASE_URL=postgres://scopeiq:scopeiq_dev@localhost:5432/scopeiq

# -- REDIS (Cache & Queues) --
REDIS_URL=redis://localhost:6379

# -- STORAGE (MinIO/S3) --
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=scopeiq
STORAGE_SECRET_KEY=scopeiq_dev
STORAGE_BUCKET=scopeiq-assets
STORAGE_USE_SSL=false

# -- AI CONFIG --
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
AI_CALLBACK_SECRET=generate_a_secure_random_secret_here

# -- SECURITY (required in production, min 32 chars) --
EMAIL_APPROVAL_SECRET=generate_a_secure_random_secret_here_min_32_chars

# -- AUTH & EXTERNAL --
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
SENTRY_DSN=...
SUPABASE_URL=...
SUPABASE_ANON_KEY=...
