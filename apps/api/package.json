        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1023.0",
        "@aws-sdk/s3-request-presigner": "^3.1023.0",
