{
  "name": "scopeiq",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:clean": "rm -rf apps/web/.next apps/web/.turbo apps/api/.turbo .turbo && turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.1.0",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "prettier": "^3.2.5",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.4"
}
