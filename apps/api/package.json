{
    "name": "@novabots/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
