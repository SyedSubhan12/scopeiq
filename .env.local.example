# ===================================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ===================================================
# Copy this file to .env.local and adjust as needed
# cp .env.local.example .env.local
# ===================================================

# -- CORE SERVICES (Local) --
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# -- CORS (Local dev) --
ALLOWED_ORIGINS=http://localhost:3000

# -- DATABASE (Local PostgreSQL) --
DATABASE_URL=postgres://scopeiq:scopeiq_dev@localhost:5432/scopeiq

# -- REDIS (Local) --
REDIS_URL=redis://localhost:6379

# -- STORAGE (Local MinIO) --
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=scopeiq
STORAGE_SECRET_KEY=scopeiq_dev
STORAGE_BUCKET=scopeiq-assets
STORAGE_USE_SSL=false

# -- AI CONFIG --
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
AI_CALLBACK_SECRET=local_dev_secret_change_me

# -- SECURITY (Local - can be shorter for dev) --
EMAIL_APPROVAL_SECRET=local_secret_min_32_chars_here

# -- AUTH & EXTERNAL (Local/Test) --
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
SENTRY_DSN=

# -- SUPABASE (Local or Dev) --
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
