        "@hono/zod-validator": "^0.1.11",
        "@novabots/db": "workspace:*",
        "@novabots/types": "workspace:*",
        "@react-email/components": "^1.0.11",
        "@sentry/node": "^7.102.1",
        "@supabase/supabase-js": "^2.39.7",
        "bullmq": "^5.1.9",
        "drizzle-orm": "^0.30.0",
        "hono": "^4.0.8",
        "ioredis": "^5.10.1",
        "pg": "^8.11.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "resend": "^3.5.0",
        "stripe": "^14.19.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
