# ===================================================
# PRODUCTION ENVIRONMENT VARIABLES (Vercel Deployment)
# ===================================================
# These should be set in Vercel Dashboard:
# Project Settings → Environment Variables
# DO NOT commit actual production secrets to git!
# ===================================================

# -- CORE SERVICES (Production) --
# Frontend URL (your Vercel deployment)
WEB_URL=https://scopeiq-web.vercel.app

# Backend API URL (your deployed API server)
# IMPORTANT: Update this to your actual production API URL
API_URL=https://api.scopeiq.app
NEXT_PUBLIC_API_URL=https://api.scopeiq.app

# AI Service URL (if self-hosted, otherwise can be omitted)
AI_SERVICE_URL=https://ai.scopeiq.app

# -- CORS (Production - your Vercel domain) --
ALLOWED_ORIGINS=https://scopeiq-web.vercel.app,https://scopeiq.app

# -- DATABASE (Production PostgreSQL) --
DATABASE_URL=postgres://user:password@host:5432/dbname

# -- REDIS (Production) --
REDIS_URL=redis://user:password@host:6379

# -- STORAGE (Production S3/MinIO) --
STORAGE_ENDPOINT=s3.amazonaws.com
STORAGE_PORT=443
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET=scopeiq-assets-production
STORAGE_USE_SSL=true

# -- AI CONFIG --
GEMINI_API_KEY=your_production_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
AI_CALLBACK_SECRET=generate_secure_random_secret_here

# -- SECURITY (Production - MUST be 32+ chars) --
EMAIL_APPROVAL_SECRET=generate_secure_random_secret_here_min_32_chars

# -- AUTH & EXTERNAL (Production) --
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_production_...
RESEND_API_KEY=re_production_...
SENTRY_DSN=https://your_sentry_dsn

# -- SUPABASE (Production) --
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key
